@{
    ViewData["Title"] = "Marketing Campaigns";
    Layout = "~/Views/Shared/_MarketingLayout.cshtml";
}

<div class="container-fluid">
    <!-- Page Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h3 mb-0">Marketing Campaigns</h1>
            <p class="text-muted mb-0">Create and manage marketing campaigns</p>
        </div>
        <div class="d-flex gap-2">
            <button class="btn btn-pdf-export" onclick="exportTableToPDF('Marketing Campaigns', 'campaignsTableBody', ['Campaign','Type','Start Date','End Date','Budget','Status'])">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg> Export PDF
            </button>
            <a href="/MarketingStaff/CreateCampaign" class="btn btn-primary">
                <i class="bi bi-plus-lg me-2"></i>New Campaign
            </a>
        </div>
    </div>

    <!-- Stats Cards -->
    <div class="row g-4 mb-4">
        <div class="col-md-3">
            <div class="stat-card stat-card-primary fade-in stagger-1">
                <div class="stat-icon"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg></div>
                <div class="stat-content">
                    <div class="stat-value" id="totalCampaigns">0</div>
                    <div class="stat-label">Total Campaigns</div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="stat-card stat-card-success fade-in stagger-2">
                <div class="stat-icon"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg></div>
                <div class="stat-content">
                    <div class="stat-value" id="activeCampaigns">0</div>
                    <div class="stat-label">Active</div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="stat-card stat-card-warning fade-in stagger-3">
                <div class="stat-icon"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg></div>
                <div class="stat-content">
                    <div class="stat-value" id="draftCampaigns">0</div>
                    <div class="stat-label">Draft</div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="stat-card stat-card-info fade-in stagger-4">
                <div class="stat-icon"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg></div>
                <div class="stat-content">
                    <div class="stat-value" id="completedCampaigns">0</div>
                    <div class="stat-label">Completed</div>
                </div>
            </div>
        </div>
    </div>

    <!-- Campaigns Table -->
    <div class="card border-0 shadow-sm">
        <div class="card-header bg-white border-0">
            <div class="row align-items-center">
                <div class="col-md-4">
                    <input type="text" class="form-control" placeholder="Search campaigns..." id="campaignSearch">
                </div>
                <div class="col-md-3">
                    <select class="form-select" id="campaignStatusFilter">
                        <option value="">All Status</option>
                        <option value="Draft">Draft</option>
                        <option value="Scheduled">Scheduled</option>
                        <option value="Active">Active</option>
                        <option value="Paused">Paused</option>
                        <option value="Completed">Completed</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <select class="form-select" id="campaignTypeFilter">
                        <option value="">All Types</option>
                        <option value="Email">Email</option>
                        <option value="Social Media">Social Media</option>
                        <option value="SMS">SMS</option>
                        <option value="Display">Display</option>
                    </select>
                </div>
            </div>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Campaign</th>
                            <th>Type</th>
                            <th>Start Date</th>
                            <th>End Date</th>
                            <th class="text-end">Budget</th>
                            <th>Status</th>
                            <th class="text-center">Actions</th>
                        </tr>
                    </thead>
                    <tbody id="campaignsTableBody">
                        <tr>
                            <td colspan="7" class="text-center py-4">Loading campaigns...</td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/marketing.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            Campaigns.load();
            
            // Filter functionality
            const searchInput = document.getElementById('campaignSearch');
            const statusFilter = document.getElementById('campaignStatusFilter');
            const typeFilter = document.getElementById('campaignTypeFilter');
            
            function filterCampaigns() {
                Campaigns.filter(
                    searchInput?.value || '',
                    statusFilter?.value || '',
                    typeFilter?.value || ''
                );
            }
            
            if (searchInput) searchInput.addEventListener('input', filterCampaigns);
            if (statusFilter) statusFilter.addEventListener('change', filterCampaigns);
            if (typeFilter) typeFilter.addEventListener('change', filterCampaigns);
        });
    </script>
}

<!-- View Campaign Modal -->
<div class="modal fade view-modal" id="viewCampaignModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title">Campaign Details</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body" id="viewCampaignContent">
                <div class="text-center py-4">
                    <div class="spinner-border text-primary" role="status"></div>
                </div>
            </div>
            <div class="modal-footer border-0">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                <button type="button" class="btn btn-warning" onclick="Campaigns.edit(Campaigns.currentId)">
                    <i class="bi bi-pencil me-1"></i>Edit
                </button>
            </div>
        </div>
    </div>
</div>

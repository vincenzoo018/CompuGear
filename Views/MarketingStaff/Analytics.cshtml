@{
    ViewData["Title"] = "Marketing Analytics";
    Layout = "~/Views/Shared/_MarketingLayout.cshtml";
}

<div class="container-fluid">
    <!-- Page Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h3 mb-0">Marketing Analytics</h1>
            <p class="text-muted mb-0">Track and analyze marketing performance</p>
        </div>
        <div class="d-flex gap-2">
            <div class="btn-group">
                <button class="btn btn-outline-primary active" data-period="week">This Week</button>
                <button class="btn btn-outline-primary" data-period="month">This Month</button>
                <button class="btn btn-outline-primary" data-period="quarter">This Quarter</button>
            </div>
            <button class="btn btn-pdf-export" onclick="generateMarketingPDF()">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg> Generate Report
            </button>
        </div>
    </div>

    <!-- Summary Cards -->
    <div class="row g-4 mb-4">
        <div class="col-md-3">
            <div class="stat-card stat-card-primary fade-in stagger-1">
                <div class="stat-icon"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg></div>
                <div class="stat-content">
                    <div class="stat-value" id="totalCampaigns">0</div>
                    <div class="stat-label">Total Campaigns</div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="stat-card stat-card-success fade-in stagger-2">
                <div class="stat-icon"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg></div>
                <div class="stat-content">
                    <div class="stat-value" id="totalReach">0</div>
                    <div class="stat-label">Total Reach</div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="stat-card stat-card-info fade-in stagger-3">
                <div class="stat-icon"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 9V5a3 3 0 0 0-3-3l-4 9v11h11.28a2 2 0 0 0 2-1.7l1.38-9a2 2 0 0 0-2-2.3zM7 22H4a2 2 0 0 1-2-2v-7a2 2 0 0 1 2-2h3"/></svg></div>
                <div class="stat-content">
                    <div class="stat-value" id="engagementRate">0%</div>
                    <div class="stat-label">Engagement Rate</div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="stat-card stat-card-warning fade-in stagger-4">
                <div class="stat-icon"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/><polyline points="17 6 23 6 23 12"/></svg></div>
                <div class="stat-content">
                    <div class="stat-value" id="roi">0%</div>
                    <div class="stat-label">ROI</div>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <!-- Performance Over Time -->
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white border-0">
                    <h5 class="mb-0">Performance Over Time</h5>
                </div>
                <div class="card-body">
                    <canvas id="performanceChart" height="300"></canvas>
                </div>
            </div>
        </div>

        <!-- Campaign Types -->
        <div class="col-lg-4">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white border-0">
                    <h5 class="mb-0">By Campaign Type</h5>
                </div>
                <div class="card-body">
                    <canvas id="campaignTypeChart" height="300"></canvas>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4 mt-2">
        <!-- Top Campaigns -->
        <div class="col-lg-6">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white border-0">
                    <h5 class="mb-0">Top Performing Campaigns</h5>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Campaign</th>
                                    <th class="text-center">Reach</th>
                                    <th class="text-center">Conversions</th>
                                    <th class="text-end">ROI</th>
                                </tr>
                            </thead>
                            <tbody id="topCampaignsTable">
                                <tr>
                                    <td colspan="4" class="text-center py-4">Loading...</td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <!-- Top Promotions -->
        <div class="col-lg-6">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white border-0">
                    <h5 class="mb-0">Top Promotions</h5>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Promotion</th>
                                    <th class="text-center">Uses</th>
                                    <th class="text-end">Revenue</th>
                                </tr>
                            </thead>
                            <tbody id="topPromotionsTable">
                                <tr>
                                    <td colspan="3" class="text-center py-4">Loading...</td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="~/js/marketing.js" asp-append-version="true"></script>
    <script>
        function generateMarketingPDF() {
            const totalCampaigns = document.getElementById('totalCampaigns')?.textContent || '0';
            const totalReach = document.getElementById('totalReach')?.textContent || '0';
            const engagementRate = document.getElementById('engagementRate')?.textContent || '0%';
            const roi = document.getElementById('roi')?.textContent || '0%';

            // Capture chart images
            const perfCanvas = document.getElementById('performanceChart');
            const typeCanvas = document.getElementById('campaignTypeChart');
            const perfImg = perfCanvas ? perfCanvas.toDataURL('image/png') : '';
            const typeImg = typeCanvas ? typeCanvas.toDataURL('image/png') : '';

            // Capture table data
            function captureTable(tbodyId, headers) {
                const tbody = document.getElementById(tbodyId);
                if (!tbody) return '';
                const rows = tbody.querySelectorAll('tr');
                if (!rows.length || (rows.length === 1 && rows[0].querySelector('td[colspan]'))) return '';
                let html = '<table style="width:100%;border-collapse:collapse;margin-top:8px;font-size:12px;">';
                html += '<thead><tr>' + headers.map(h => `<th style="padding:6px 10px;border:1px solid #ddd;background:#008080;color:#fff;text-align:left;">${h}</th>`).join('') + '</tr></thead><tbody>';
                rows.forEach(tr => {
                    html += '<tr>';
                    tr.querySelectorAll('td').forEach(td => {
                        html += `<td style="padding:5px 10px;border:1px solid #ddd;">${td.textContent.trim()}</td>`;
                    });
                    html += '</tr>';
                });
                html += '</tbody></table>';
                return html;
            }

            const campaignsTable = captureTable('topCampaignsTable', ['Campaign', 'Reach', 'Conversions', 'ROI']);
            const promotionsTable = captureTable('topPromotionsTable', ['Promotion', 'Uses', 'Revenue']);

            const now = new Date();
            const html = `<!DOCTYPE html><html><head><title>Marketing Analytics Report</title>
            <style>
                body { font-family: 'Segoe UI', Arial, sans-serif; margin: 30px; color: #333; }
                .header { text-align: center; border-bottom: 2px solid #008080; padding-bottom: 12px; margin-bottom: 20px; }
                .header h1 { color: #008080; margin: 0 0 4px 0; font-size: 22px; }
                .header p { margin: 0; font-size: 12px; color: #666; }
                .stats { display: flex; gap: 16px; margin-bottom: 24px; }
                .stat-box { flex: 1; border: 1px solid #ddd; border-radius: 8px; padding: 14px; text-align: center; }
                .stat-box .label { font-size: 11px; color: #666; text-transform: uppercase; }
                .stat-box .value { font-size: 20px; font-weight: 700; color: #008080; margin-top: 4px; }
                .charts { display: flex; gap: 20px; margin-bottom: 24px; }
                .chart-box { text-align: center; }
                .chart-box.wide { flex: 2; }
                .chart-box.narrow { flex: 1; }
                .chart-box h3 { font-size: 14px; color: #555; margin-bottom: 10px; }
                .chart-box img { max-width: 100%; max-height: 250px; }
                .section-title { font-size: 15px; font-weight: 600; color: #008080; margin: 20px 0 8px 0; }
                .tables { display: flex; gap: 20px; }
                .table-box { flex: 1; }
                .footer { text-align: center; margin-top: 30px; padding-top: 12px; border-top: 1px solid #ddd; font-size: 11px; color: #999; }
                @@media print { body { margin: 15px; } }
            </style></head><body>
            <div class="header">
                <h1>CompuGear - Marketing Analytics Report</h1>
                <p>Generated: ${now.toLocaleString()}</p>
            </div>
            <div class="stats">
                <div class="stat-box"><div class="label">Total Campaigns</div><div class="value">${totalCampaigns}</div></div>
                <div class="stat-box"><div class="label">Total Reach</div><div class="value">${totalReach}</div></div>
                <div class="stat-box"><div class="label">Engagement Rate</div><div class="value">${engagementRate}</div></div>
                <div class="stat-box"><div class="label">ROI</div><div class="value">${roi}</div></div>
            </div>
            <div class="charts">
                ${perfImg ? `<div class="chart-box wide"><h3>Performance Over Time</h3><img src="${perfImg}"></div>` : ''}
                ${typeImg ? `<div class="chart-box narrow"><h3>By Campaign Type</h3><img src="${typeImg}"></div>` : ''}
            </div>
            <div class="tables">
                ${campaignsTable ? `<div class="table-box"><div class="section-title">Top Performing Campaigns</div>${campaignsTable}</div>` : ''}
                ${promotionsTable ? `<div class="table-box"><div class="section-title">Top Promotions</div>${promotionsTable}</div>` : ''}
            </div>
            <div class="footer">CompuGear Marketing Management System</div>
            <script>window.onload=function(){window.print();}<\/script>
            </body></html>`;

            const w = window.open('', '_blank');
            w.document.write(html);
            w.document.close();
        }
    </script>
}

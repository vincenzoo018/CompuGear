@{
    ViewData["Title"] = "Chart of Accounts";
    Layout = "~/Views/Shared/_BillingLayout.cshtml";
}

<div class="page-header d-flex justify-content-between align-items-center flex-wrap gap-3">
    <div>
        <h1 class="page-title">Chart of Accounts</h1>
        <p class="page-subtitle">Manage your financial account structure</p>
    </div>
    <div class="d-flex gap-2">
        <button class="btn btn-outline-success" id="seedDefaultsBtn" onclick="seedDefaultAccounts()" style="display:none;">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M12 3v18m-9-9h18"/>
            </svg>
            Seed Default Accounts
        </button>
        <button class="btn btn-outline-primary" onclick="exportCOA()">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/>
            </svg>
            Export
        </button>
        <button class="btn btn-primary" onclick="COA.openCreate()">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/>
            </svg>
            Add Account
        </button>
    </div>
</div>

<!-- Stats -->
<div class="row mb-4">
    <div class="col-xl-3 col-md-6 mb-3">
        <div class="stat-card stat-card-primary fade-in stagger-1">
            <div class="stat-icon"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 2v20l2-1 2 1 2-1 2 1 2-1 2 1 2-1 2 1V2l-2 1-2-1-2 1-2-1-2 1-2-1-2 1z"/></svg></div>
            <div class="stat-content">
                <div class="stat-value" id="totalAccounts">0</div>
                <div class="stat-label">Total Accounts</div>
            </div>
        </div>
    </div>
    <div class="col-xl-3 col-md-6 mb-3">
        <div class="stat-card stat-card-success fade-in stagger-2">
            <div class="stat-icon"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 3h-8l-2 4h12z"/></svg></div>
            <div class="stat-content">
                <div class="stat-value" id="assetAccounts">0</div>
                <div class="stat-label">Asset Accounts</div>
            </div>
        </div>
    </div>
    <div class="col-xl-3 col-md-6 mb-3">
        <div class="stat-card stat-card-warning fade-in stagger-3">
            <div class="stat-icon"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg></div>
            <div class="stat-content">
                <div class="stat-value" id="revenueAccounts">0</div>
                <div class="stat-label">Revenue Accounts</div>
            </div>
        </div>
    </div>
    <div class="col-xl-3 col-md-6 mb-3">
        <div class="stat-card stat-card-danger fade-in stagger-4">
            <div class="stat-icon"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/><polyline points="17 6 23 6 23 12"/></svg></div>
            <div class="stat-content">
                <div class="stat-value" id="expenseAccounts">0</div>
                <div class="stat-label">Expense Accounts</div>
            </div>
        </div>
    </div>
</div>

<!-- Filter -->
<div class="card mb-4 fade-in">
    <div class="card-body">
        <div class="row g-3 align-items-end">
            <div class="col-md-4">
                <label class="form-label">Search</label>
                <input type="text" class="form-control" id="coaSearch" placeholder="Search by code or name...">
            </div>
            <div class="col-md-3">
                <label class="form-label">Account Type</label>
                <select class="form-select" id="coaTypeFilter">
                    <option value="">All Types</option>
                    <option value="Asset">Asset</option>
                    <option value="Liability">Liability</option>
                    <option value="Equity">Equity</option>
                    <option value="Revenue">Revenue</option>
                    <option value="Expense">Expense</option>
                </select>
            </div>
            <div class="col-md-2">
                <label class="form-label">Status</label>
                <select class="form-select" id="coaStatusFilter">
                    <option value="">All</option>
                    <option value="active">Active</option>
                    <option value="inactive">Inactive</option>
                </select>
            </div>
            <div class="col-md-3">
                <div class="d-flex gap-2">
                    <button class="btn btn-outline-secondary flex-fill" onclick="COA.load()">Reset</button>
                    <button class="btn btn-outline-primary flex-fill" onclick="COA.applyFilters()">Filter</button>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Table -->
<div class="card fade-in">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="mb-0">Account List</h5>
        <span class="badge bg-primary" id="coaCount">0 accounts</span>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="data-table">
                <thead>
                    <tr>
                        <th>Code</th>
                        <th>Account Name</th>
                        <th>Type</th>
                        <th>Normal Balance</th>
                        <th class="text-end">Debit</th>
                        <th class="text-end">Credit</th>
                        <th class="text-end">Balance</th>
                        <th>Status</th>
                        <th class="text-center" style="width: 160px;">Actions</th>
                    </tr>
                </thead>
                <tbody id="coaTableBody">
                    <tr><td colspan="9" class="text-center py-4">Loading accounts...</td></tr>
                </tbody>
            </table>
        </div>
    </div>
    <div class="card-footer d-flex justify-content-between align-items-center" id="coaPagination"></div>
</div>

<!-- Create/Edit Account Modal -->
<div class="modal fade" id="coaModal" tabindex="-1">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header" style="background: #008080; color: white;">
                <h5 class="modal-title"><span id="coaModalTitle">Add Account</span></h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <form id="coaForm" onsubmit="COA.save(event)">
                <div class="modal-body">
                    <input type="hidden" id="coaId" value="0">
                    <div class="row g-3">
                        <div class="col-md-4">
                            <label class="form-label required">Account Code</label>
                            <input type="text" class="form-control" id="coaCode" required placeholder="e.g. 1000">
                        </div>
                        <div class="col-md-8">
                            <label class="form-label required">Account Name</label>
                            <input type="text" class="form-control" id="coaName" required placeholder="e.g. Cash">
                        </div>
                        <div class="col-md-4">
                            <label class="form-label required">Account Type</label>
                            <select class="form-select" id="coaType" required>
                                <option value="Asset">Asset</option>
                                <option value="Liability">Liability</option>
                                <option value="Equity">Equity</option>
                                <option value="Revenue">Revenue</option>
                                <option value="Expense">Expense</option>
                            </select>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Normal Balance</label>
                            <select class="form-select" id="coaNormalBalance">
                                <option value="Debit">Debit</option>
                                <option value="Credit">Credit</option>
                            </select>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Parent Account</label>
                            <select class="form-select" id="coaParent">
                                <option value="">None (Top Level)</option>
                            </select>
                        </div>
                        <div class="col-12">
                            <label class="form-label">Description</label>
                            <textarea class="form-control" id="coaDescription" rows="2" placeholder="Account description..."></textarea>
                        </div>
                        <div class="col-md-6">
                            <div class="form-check form-switch">
                                <input class="form-check-input" type="checkbox" id="coaActive" checked>
                                <label class="form-check-label" for="coaActive">Active</label>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">Save Account</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- View Account Modal -->
<div class="modal fade" id="viewCoaModal" tabindex="-1">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header" style="background: #008080; color: white;">
                <h5 class="modal-title">Account Details</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body" id="viewCoaContent">
                <div class="text-center py-4"><div class="spinner-border text-primary"></div></div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/billing.js"></script>
    <script src="~/js/accounting.js"></script>
    <script>
    // Override COA.load to show/hide seed button
    const _originalCoaLoad = COA.load.bind(COA);
    COA.load = async function() {
        await _originalCoaLoad();
        const seedBtn = document.getElementById('seedDefaultsBtn');
        if (seedBtn) seedBtn.style.display = this.data.length === 0 ? '' : 'none';
    };

    document.addEventListener('DOMContentLoaded', function() {
        COA.load();
        document.getElementById('coaSearch').addEventListener('input', () => COA.applyFilters());
        document.getElementById('coaTypeFilter').addEventListener('change', () => COA.applyFilters());
        document.getElementById('coaStatusFilter').addEventListener('change', () => COA.applyFilters());
        document.getElementById('coaType').addEventListener('change', function() {
            const nb = document.getElementById('coaNormalBalance');
            if (['Asset','Expense'].includes(this.value)) nb.value = 'Debit';
            else nb.value = 'Credit';
        });
    });

    async function seedDefaultAccounts() {
        if (!confirm('This will create 25 default accounts (Assets, Liabilities, Equity, Revenue, Expenses). Continue?')) return;
        try {
            const btn = document.getElementById('seedDefaultsBtn');
            if (btn) { btn.disabled = true; btn.innerHTML = '<span class="spinner-border spinner-border-sm"></span> Creating...'; }
            await API.post('/chart-of-accounts/seed-defaults', {});
            Toast.success('Default accounts created successfully!');
            await COA.load();
        } catch (error) {
            Toast.error(error.message || 'Failed to seed default accounts');
        } finally {
            const btn = document.getElementById('seedDefaultsBtn');
            if (btn) { btn.disabled = false; btn.innerHTML = '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 3v18m-9-9h18"/></svg> Seed Default Accounts'; }
        }
    }

    function exportCOA() {
        const data = COA.data;
        if (!data || data.length === 0) { Toast.error('No accounts to export'); return; }
        const csv = [['Code','Name','Type','Normal Balance','Status','Description'].join(','),
            ...data.map(a => [a.accountCode, `"${a.accountName}"`, a.accountType, a.normalBalance, a.isActive?'Active':'Inactive', `"${a.description||''}"`].join(','))
        ].join('\n');
        const blob = new Blob([csv], {type:'text/csv'});
        const url = URL.createObjectURL(blob);
        const a = document.createElement('a'); a.href = url; a.download = `chart_of_accounts_${new Date().toISOString().split('T')[0]}.csv`; a.click();
        Toast.success('Exported successfully');
    }
    </script>
}

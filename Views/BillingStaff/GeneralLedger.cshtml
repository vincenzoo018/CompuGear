@{
    ViewData["Title"] = "General Ledger";
    Layout = "~/Views/Shared/_BillingLayout.cshtml";
}

<div class="page-header d-flex justify-content-between align-items-center flex-wrap gap-3">
    <div>
        <h1 class="page-title">General Ledger</h1>
        <p class="page-subtitle">View all posted transactions and account balances</p>
    </div>
    <div>
        <button class="btn btn-pdf-export" onclick="exportGL()"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg> Export PDF</button>
    </div>
</div>

<!-- Stats -->
<div class="row mb-4">
    <div class="col-xl-3 col-md-6 mb-3">
        <div class="stat-card stat-card-primary fade-in stagger-1">
            <div class="stat-icon"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg></div>
            <div class="stat-content">
                <div class="stat-value" id="glTransactions">0</div>
                <div class="stat-label">Transactions</div>
            </div>
        </div>
    </div>
    <div class="col-xl-3 col-md-6 mb-3">
        <div class="stat-card stat-card-success fade-in stagger-2">
            <div class="stat-icon"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/><polyline points="17 6 23 6 23 12"/></svg></div>
            <div class="stat-content">
                <div class="stat-value" id="glTotalDebit">₱0</div>
                <div class="stat-label">Total Debits</div>
            </div>
        </div>
    </div>
    <div class="col-xl-3 col-md-6 mb-3">
        <div class="stat-card stat-card-danger fade-in stagger-3">
            <div class="stat-icon"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="23 18 13.5 8.5 8.5 13.5 1 6"/><polyline points="17 18 23 18 23 12"/></svg></div>
            <div class="stat-content">
                <div class="stat-value" id="glTotalCredit">₱0</div>
                <div class="stat-label">Total Credits</div>
            </div>
        </div>
    </div>
    <div class="col-xl-3 col-md-6 mb-3">
        <div class="stat-card stat-card-info fade-in stagger-4">
            <div class="stat-icon"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 2v20l2-1 2 1 2-1 2 1 2-1 2 1 2-1 2 1V2l-2 1-2-1-2 1-2-1-2 1-2-1-2 1z"/></svg></div>
            <div class="stat-content">
                <div class="stat-value" id="glAccounts">0</div>
                <div class="stat-label">Active Accounts</div>
            </div>
        </div>
    </div>
</div>

<!-- Filter -->
<div class="card mb-4 fade-in">
    <div class="card-body">
        <div class="row g-3 align-items-end">
            <div class="col-md-3">
                <label class="form-label">Account</label>
                <select class="form-select" id="glAccountFilter">
                    <option value="">All Accounts</option>
                </select>
            </div>
            <div class="col-md-2">
                <label class="form-label">Source</label>
                <select class="form-select" id="glSourceFilter">
                    <option value="">All Sources</option>
                    <option value="Manual">Manual</option>
                    <option value="System">System</option>
                    <option value="Invoice">Invoice</option>
                    <option value="Payment">Payment</option>
                    <option value="Refund">Refund</option>
                    <option value="COGS">COGS</option>
                    <option value="Tax">Tax</option>
                </select>
            </div>
            <div class="col-md-2">
                <label class="form-label">Date From</label>
                <input type="date" class="form-control" id="glDateFrom">
            </div>
            <div class="col-md-2">
                <label class="form-label">Date To</label>
                <input type="date" class="form-control" id="glDateTo">
            </div>
            <div class="col-md-3">
                <div class="d-flex gap-2 align-items-end h-100">
                    <div class="flex-fill">
                        <label class="form-label">Search</label>
                        <input type="text" class="form-control" id="glSearch" placeholder="Search...">
                    </div>
                    <button class="btn btn-outline-secondary" onclick="GL.load()" title="Reset">Reset</button>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Account Summary -->
<div class="card mb-4 fade-in">
    <div class="card-header">
        <h5 class="mb-0">Account Summary (Trial Balance)</h5>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="data-table">
                <thead>
                    <tr>
                        <th>Account Code</th>
                        <th>Account Name</th>
                        <th>Type</th>
                        <th class="text-end">Total Debits</th>
                        <th class="text-end">Total Credits</th>
                        <th class="text-end">Balance</th>
                    </tr>
                </thead>
                <tbody id="glSummaryBody">
                    <tr><td colspan="6" class="text-center py-4">Loading...</td></tr>
                </tbody>
                <tfoot id="glSummaryFooter"></tfoot>
            </table>
        </div>
    </div>
</div>

<!-- Ledger Transactions -->
<div class="card fade-in">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="mb-0">Ledger Transactions</h5>
        <span class="badge bg-primary" id="glCount">0 transactions</span>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="data-table">
                <thead>
                    <tr>
                        <th>Date</th>
                        <th>Account</th>
                        <th>Description</th>
                        <th>Reference</th>
                        <th>Source</th>
                        <th class="text-end">Debit</th>
                        <th class="text-end">Credit</th>
                        <th class="text-end">Balance</th>
                        <th class="text-center" style="width:80px;">Actions</th>
                    </tr>
                </thead>
                <tbody id="glTableBody">
                    <tr><td colspan="9" class="text-center py-4">Loading ledger transactions...</td></tr>
                </tbody>
            </table>
        </div>
    </div>
    <div class="card-footer d-flex justify-content-between align-items-center" id="glPagination"></div>
</div>

@section Scripts {
    <script src="~/js/billing.js"></script>
    <script src="~/js/accounting.js"></script>
    <script>
    document.addEventListener('DOMContentLoaded', function() {
        GL.load();
        document.getElementById('glAccountFilter').addEventListener('change', () => GL.applyFilters());
        document.getElementById('glSourceFilter').addEventListener('change', () => GL.applyFilters());
        document.getElementById('glDateFrom').addEventListener('change', () => GL.applyFilters());
        document.getElementById('glDateTo').addEventListener('change', () => GL.applyFilters());
        document.getElementById('glSearch').addEventListener('input', () => GL.applyFilters());
    });

    function exportGL() {
        const data = GL.data;
        if (!data || data.length === 0) { Toast.error('No data to export'); return; }
        var headers = ['Date', 'Account', 'Description', 'Reference', 'Debit', 'Credit', 'Running Balance'];
        var rows = [];
        data.forEach(function(t) {
            rows.push([new Date(t.transactionDate).toLocaleDateString(), t.accountName || '', t.description || '', t.reference || '', t.debitAmount?.toFixed(2) || '0.00', t.creditAmount?.toFixed(2) || '0.00', t.runningBalance?.toFixed(2) || '0.00']);
        });
        exportDataToPDF('General Ledger', headers, rows);
    }
    </script>
}

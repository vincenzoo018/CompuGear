@{
    ViewData["Title"] = "Customer Accounts";
    Layout = "~/Views/Shared/_BillingLayout.cshtml";
}

<div class="page-header d-flex justify-content-between align-items-center flex-wrap gap-3">
    <div>
        <h1 class="page-title">Customer Accounts</h1>
        <p class="page-subtitle">View customer account balances and history</p>
    </div>
    <button class="btn btn-pdf-export" onclick="exportTableToPDF('Customer Accounts', 'accountsTableBody', ['Account #','Customer','Orders','Total Spent','Balance'])">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg> Export PDF
    </button>
</div>

<!-- Search -->
<div class="card mb-4 fade-in">
    <div class="card-body">
        <div class="row">
            <div class="col-md-6">
                <input type="text" class="form-control form-control-lg" placeholder="Search customers by name, email, or account..." id="accountSearch">
            </div>
        </div>
    </div>
</div>

<!-- Accounts Table -->
<div class="card fade-in">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="data-table">
                <thead>
                    <tr>
                        <th>Account #</th>
                        <th>Customer</th>
                        <th class="text-center">Orders</th>
                        <th class="text-end">Total Spent</th>
                        <th class="text-end">Balance</th>
                        <th class="text-center">Actions</th>
                    </tr>
                </thead>
                <tbody id="accountsTableBody">
                    <tr>
                        <td colspan="6" class="text-center py-4">Loading accounts...</td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/billing.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            CustomerAccounts.load();
            
            // Filter functionality
            const searchInput = document.getElementById('accountSearch');
            if (searchInput) {
                searchInput.addEventListener('input', function() {
                    CustomerAccounts.filter(this.value);
                });
            }
        });
    </script>
}

<!-- View Account Modal -->
<div class="modal fade view-modal" id="viewAccountModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title">Account Details</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body" id="viewAccountContent">
                <div class="text-center py-4">
                    <div class="spinner-border text-primary" role="status"></div>
                </div>
            </div>
            <div class="modal-footer border-0">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>

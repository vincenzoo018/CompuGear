@{
    Layout = "~/Views/ERPWebsite/_ERPWebsiteLayout.cshtml";
    ViewData["Title"] = "Payment Cancelled";
    ViewData["ActivePage"] = "Pricing";
}

@section Styles {
    .cancelled-page {
        padding: 80px 24px 120px;
        background: linear-gradient(180deg, #f0f9f9 0%, #f8f9fc 100%);
        min-height: 80vh;
        display: flex; align-items: center; justify-content: center;
        position: relative; overflow: hidden;
    }
    .cancelled-page::before {
        content:''; position:absolute; bottom:-100px; left:-100px;
        width:350px; height:350px;
        background:radial-gradient(circle,rgba(245,158,11,0.06) 0%,transparent 70%);
        border-radius:50%;
    }

    .cancelled-card {
        background: #fff; border-radius: 22px;
        padding: 56px 48px; max-width: 500px; width: 100%;
        text-align: center;
        box-shadow: 0 20px 60px rgba(0,0,0,0.08);
        border: 1px solid #eef0f3;
    }

    .cancelled-icon {
        width: 88px; height: 88px; border-radius: 50%;
        background: linear-gradient(135deg, #f59e0b, #d97706);
        color: #fff;
        display: flex; align-items: center; justify-content: center;
        margin: 0 auto 24px;
        animation: iconPop 0.5s cubic-bezier(.4,0,.2,1) forwards;
    }
    @@keyframes iconPop {
        0% { transform: scale(0.5); opacity: 0; }
        70% { transform: scale(1.1); }
        100% { transform: scale(1); opacity: 1; }
    }

    .cancelled-card h2 {
        font-size: 1.6rem; font-weight: 700; color: #1a1a2e; margin-bottom: 12px;
    }
    .cancelled-card p {
        font-size: 0.95rem; color: #777; line-height: 1.7; margin-bottom: 28px;
    }

    .cancelled-actions {
        display: flex; flex-direction: column; align-items: center; gap: 12px;
    }

    .btn-back {
        display: inline-block; padding: 14px 48px;
        background: linear-gradient(135deg, #008080, #006666);
        color: #fff; border-radius: 14px; font-weight: 600; font-size: 1rem;
        transition: all 0.3s cubic-bezier(.4,0,.2,1);
        box-shadow: 0 8px 24px rgba(0,128,128,0.18);
    }
    .btn-back:hover { transform: translateY(-3px); box-shadow: 0 12px 32px rgba(0,128,128,0.28); }

    .btn-pricing {
        display: inline-block; padding: 12px 36px;
        background: #fff; color: #008080;
        border: 2px solid #e2e8f0; border-radius: 14px;
        font-weight: 600; font-size: 0.95rem;
        transition: all 0.3s;
    }
    .btn-pricing:hover { border-color: #008080; background: rgba(0,128,128,0.04); transform: translateY(-2px); }

    @@media (max-width: 768px) {
        .cancelled-card { padding: 40px 24px; border-radius: 18px; }
    }
}

<section class="cancelled-page">
    <div class="cancelled-card anim-fade-up">
        <div class="cancelled-icon">
            <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <circle cx="12" cy="12" r="10"/>
                <line x1="12" y1="8" x2="12" y2="12"/>
                <line x1="12" y1="16" x2="12.01" y2="16"/>
            </svg>
        </div>
        <h2>Payment Cancelled</h2>
        <p>Your payment was not completed. No charges have been made to your account. You can try again whenever you're ready.</p>
        <div class="cancelled-actions">
            <a href="/ERPWebsite/Subscribe?plan=@ViewData["SelectedPlan"]" class="btn-back">Try Again</a>
            <a href="/ERPWebsite/Pricing" class="btn-pricing">View Plans</a>
        </div>
    </div>
</section>

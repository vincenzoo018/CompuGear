<!-- FAQ -->
<section class="faq-section reveal">
    <h2>Frequently Asked Questions</h2>

    <div class="faq-item" onclick="this.classList.toggle('open')">
        <div class="faq-q">
            What modules are included in each plan?
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="6 9 12 15 18 9"/></svg>
        </div>
        <div class="faq-a">Starter includes Sales and Inventory. Pro includes all modules: Sales, Inventory, Billing, Customer, Support, and Marketing. Enterprise includes everything in Pro plus a dedicated account manager and phone support.</div>
    </div>

    <div class="faq-item" onclick="this.classList.toggle('open')">
        <div class="faq-q">
            Can I upgrade my plan later?
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="6 9 12 15 18 9"/></svg>
        </div>

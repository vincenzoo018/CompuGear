@{
    Layout = "~/Views/ERPWebsite/_ERPWebsiteLayout.cshtml";
    ViewData["Title"] = "Pricing";
    ViewData["ActivePage"] = "Pricing";
}

@section Styles {
    /* ===== HERO ===== */
    .pricing-hero {
        background: linear-gradient(180deg, #f0f9f9 0%, #f8f9fc 100%);
        padding: 90px 24px 50px; text-align: center;
        position: relative; overflow: hidden;
    }
    .pricing-hero::before {
        content:''; position:absolute; top:-180px; right:-180px;
        width:500px; height:500px;
        background:radial-gradient(circle,rgba(0,128,128,0.07) 0%,transparent 70%);
        border-radius:50%;
    }
    .pricing-hero .badge-tag {
        display:inline-flex; align-items:center; gap:6px;
        background:rgba(0,128,128,0.08); border:1px solid rgba(0,128,128,0.15);
        padding:8px 20px; border-radius:50px;
        font-size:0.88rem; font-weight:500; color:#008080; margin-bottom:22px;
    }
    .pricing-hero h1 {
        font-size: 2.8rem; font-weight: 800; color: #1a1a2e; margin-bottom: 16px;
    }
    .pricing-hero p {
        font-size: 1.1rem; color: #666; max-width: 580px; margin: 0 auto;
    }
    .hero-logo {
        display: block; width: 280px; margin: 0 auto 28px; object-fit: contain;
        filter: drop-shadow(0 6px 20px rgba(0,128,128,0.25));
        animation: heroLogoFloat 5s ease-in-out infinite;
    }
    @@keyframes heroLogoFloat {
        0%, 100% { transform: translateY(0) scale(1); }
        50% { transform: translateY(-8px) scale(1.02); }
    }

    /* Toggle */
    .billing-toggle {
        display:flex; align-items:center; justify-content:center;
        gap:14px; margin-top:32px;
    }
    .billing-toggle span { font-size:0.95rem; font-weight:500; color:#888; transition:color 0.3s; }
    .billing-toggle span.active { color:#1a1a2e; font-weight:600; }
    .billing-toggle .toggle-track {
        width:52px; height:28px; border-radius:14px;
        background:#ccc; position:relative; cursor:pointer;
        transition:background 0.3s;
    }
    .billing-toggle .toggle-track.annual { background:#008080; }
    .billing-toggle .toggle-track .toggle-thumb {
        position:absolute; top:3px; left:3px;
        width:22px; height:22px; border-radius:50%;
        background:#fff; transition:transform 0.3s;
        box-shadow:0 2px 6px rgba(0,0,0,0.15);
    }
    .billing-toggle .toggle-track.annual .toggle-thumb { transform:translateX(24px); }
    .billing-toggle .save-badge {
        background:#10B981; color:#fff; font-size:0.75rem;
        font-weight:600; padding:3px 10px; border-radius:20px;
    }

    /* ===== CARDS ===== */
    .pricing-section { padding: 50px 24px 80px; }
    .pricing-grid {
        max-width: 1120px; margin: 0 auto;
        display: grid; grid-template-columns: repeat(3, 1fr); gap: 28px;
        align-items: start;
    }

    .price-card {
        background: #fff; border-radius: 20px; padding: 40px 32px;
        border: 2px solid #eee; position: relative;
        transition: all 0.4s cubic-bezier(.4,0,.2,1);
    }
    .price-card:hover {
        transform: translateY(-6px);
        box-shadow: 0 20px 50px rgba(0,0,0,0.10);
        border-color: rgba(0,128,128,0.25);
    }
    .price-card.popular {
        border-color: #008080;
        box-shadow: 0 12px 40px rgba(0,128,128,0.12);
    }
    .price-card.popular:hover {
        box-shadow: 0 24px 56px rgba(0,128,128,0.18);
    }
    .price-card .popular-badge {
        position: absolute; top: -14px; left: 50%; transform: translateX(-50%);
        background: linear-gradient(135deg, #008080, #00a5a5); color: #fff;
        padding: 5px 22px; border-radius: 20px;
        font-size: 0.78rem; font-weight: 600; white-space: nowrap;
        box-shadow: 0 4px 12px rgba(0,128,128,0.25);
    }

    .price-card .plan-icon {
        width:52px; height:52px; border-radius:14px;
        display:flex; align-items:center; justify-content:center;
        margin-bottom:18px;
    }
    .price-card .plan-icon svg { width:26px; height:26px; }
    .icon-starter { background:rgba(59,130,246,0.1); color:#3B82F6; }
    .icon-pro { background:rgba(0,128,128,0.1); color:#008080; }
    .icon-enterprise { background:rgba(139,92,246,0.1); color:#8B5CF6; }

    .price-card .plan-name { font-size: 1.35rem; font-weight: 700; color: #1a1a2e; }
    .price-card .plan-desc { font-size: 0.88rem; color: #888; margin-top: 4px; margin-bottom: 24px; }

    .price-card .plan-price { margin-bottom: 6px; }
    .price-card .plan-price .currency { font-size: 1.3rem; font-weight: 700; color: #1a1a2e; vertical-align: top; line-height: 2; }
    .price-card .plan-price .amount { font-size: 3rem; font-weight: 800; color: #1a1a2e; transition: all 0.3s; }
    .price-card .plan-price .period { font-size: 0.95rem; color: #999; margin-left: 4px; }
    .price-card .annual-note { font-size: 0.82rem; color: #aaa; margin-bottom: 26px; min-height:20px; }

    .price-card .features-list { list-style: none; margin-bottom: 30px; }
    .price-card .features-list li {
        display: flex; align-items: center; gap: 10px;
        padding: 7px 0; font-size: 0.92rem; color: #555;
    }
    .price-card .features-list li.included svg { color: #10B981; }
    .price-card .features-list li.excluded { color: #ccc; }
    .price-card .features-list li.excluded svg { color: #ddd; }

    .price-card .btn-plan {
        display: block; width: 100%; padding: 14px 0; text-align: center;
        border-radius: 12px; font-weight: 600; font-size: 1rem;
        transition: all 0.3s cubic-bezier(.4,0,.2,1); cursor: pointer; border: 2px solid;
    }
    .price-card .btn-plan.btn-outline {
        background: #fff; color: #008080; border-color: #008080;
    }
    .price-card .btn-plan.btn-outline:hover { background: rgba(0,128,128,0.06); transform:translateY(-1px); }
    .price-card .btn-plan.btn-solid {
        background: linear-gradient(135deg, #008080, #00a5a5); color: #fff; border-color: transparent;
        box-shadow: 0 4px 14px rgba(0,128,128,0.25);
    }
    .price-card .btn-plan.btn-solid:hover { box-shadow: 0 8px 22px rgba(0,128,128,0.35); transform:translateY(-1px); }
    .price-card .btn-plan.btn-dark {
        background: linear-gradient(135deg, #1a1a2e, #2d2d4e); color: #fff; border-color: transparent;
        box-shadow: 0 4px 14px rgba(26,26,46,0.25);
    }
    .price-card .btn-plan.btn-dark:hover { box-shadow: 0 8px 22px rgba(26,26,46,0.35); transform:translateY(-1px); }

    /* ===== ENTERPRISE CTA ===== */
    .enterprise-section {
        max-width: 1120px; margin: 0 auto 60px; padding: 48px 44px;
        background: linear-gradient(135deg, #1a1a2e 0%, #2d2d4e 100%);
        border-radius: 20px; color: #fff;
        display: flex; align-items: center; justify-content: space-between; gap: 40px;
        position:relative; overflow:hidden;
    }
    .enterprise-section::before {
        content:''; position:absolute; top:-60px; right:-60px;
        width:200px; height:200px;
        background:radial-gradient(circle,rgba(0,128,128,0.2) 0%,transparent 70%);
        border-radius:50%;
    }
    .enterprise-section h3 { font-size: 1.5rem; font-weight: 700; margin-bottom: 8px; }
    .enterprise-section p { font-size: 0.95rem; opacity: 0.8; max-width: 520px; }
    .enterprise-section .btn-contact {
        flex-shrink: 0; background: #fff; color: #1a1a2e;
        padding: 14px 36px; border-radius: 12px; font-weight: 600;
        transition: all 0.3s; white-space: nowrap;
        box-shadow: 0 4px 14px rgba(0,0,0,0.1);
    }
    .enterprise-section .btn-contact:hover { transform: translateY(-2px); box-shadow: 0 8px 20px rgba(0,0,0,0.2); }

    /* ===== COMPARISON TABLE ===== */
    .comparison-section { max-width: 1120px; margin: 0 auto; padding: 0 24px 60px; }
    .comparison-section h2 { text-align:center; font-size:2rem; font-weight:700; color:#1a1a2e; margin-bottom:36px; }
    .comparison-table {
        width:100%; border-collapse:collapse; background:#fff;
        border-radius:16px; overflow:hidden;
        box-shadow:0 4px 20px rgba(0,0,0,0.05);
    }
    .comparison-table thead th {
        background:#f8f9fc; padding:16px 20px; text-align:center;
        font-size:0.9rem; font-weight:600; color:#1a1a2e; border-bottom:2px solid #eee;
    }
    .comparison-table thead th:first-child { text-align:left; }
    .comparison-table thead th.highlight { color:#008080; background:rgba(0,128,128,0.04); }
    .comparison-table tbody td {
        padding:14px 20px; text-align:center; font-size:0.9rem; color:#555;
        border-bottom:1px solid #f0f0f0;
    }
    .comparison-table tbody td:first-child { text-align:left; font-weight:500; color:#333; }
    .comparison-table tbody td.highlight { background:rgba(0,128,128,0.02); }
    .comparison-table tbody tr:last-child td { border-bottom:none; }
    .comparison-table .check-icon { color:#10B981; font-weight:700; }
    .comparison-table .cross-icon { color:#ddd; }

    /* ===== FAQ ===== */
    .faq-section { max-width: 740px; margin: 0 auto; padding: 0 24px 80px; }
    .faq-section h2 { text-align: center; font-size: 2rem; font-weight: 700; color: #1a1a2e; margin-bottom: 40px; }
    .faq-item {
        border: 1px solid #eee; border-radius: 12px; margin-bottom: 12px;
        overflow:hidden; transition: all 0.3s; background:#fff;
    }
    .faq-item:hover { border-color:rgba(0,128,128,0.2); }
    .faq-item .faq-q {
        display: flex; justify-content: space-between; align-items: center;
        font-weight: 600; font-size: 0.95rem; color: #1a1a2e;
        padding:18px 24px; cursor:pointer;
    }
    .faq-item .faq-q svg { transition: transform 0.3s; flex-shrink: 0; color: #008080; }
    .faq-item.open .faq-q svg { transform: rotate(180deg); }
    .faq-item .faq-a {
        max-height: 0; overflow: hidden; transition: max-height 0.4s ease, padding 0.3s ease;
        font-size: 0.9rem; color: #777; line-height: 1.7; padding:0 24px;
    }
    .faq-item.open .faq-a { max-height: 200px; padding: 0 24px 18px; }

    @@media (max-width: 900px) {
        .pricing-grid { grid-template-columns: 1fr; max-width: 420px; margin:0 auto; }
        .price-card.popular { order:-1; }
    }
    @@media (max-width: 768px) {
        .pricing-hero h1 { font-size: 2rem; }
        .enterprise-section { flex-direction: column; text-align: center; padding:36px 28px; }
        .comparison-table { font-size:0.82rem; }
        .comparison-table thead th, .comparison-table tbody td { padding:10px 12px; }
    }
}

<!-- Hero -->

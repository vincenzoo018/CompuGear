@section Scripts {
    <script>
        let isAnnual = false;

        function toggleBilling() {
            isAnnual = !isAnnual;
            const track = document.getElementById('billingToggle');
            const lblM = document.getElementById('lblMonthly');
            const lblA = document.getElementById('lblAnnual');

            track.classList.toggle('annual', isAnnual);
            lblM.classList.toggle('active', !isAnnual);
            lblA.classList.toggle('active', isAnnual);

            // Update prices with a subtle transition
            document.querySelectorAll('.plan-price .amount').forEach(el => {
                el.style.opacity = '0';
                el.style.transform = 'translateY(-8px)';
                setTimeout(() => {
                    el.textContent = isAnnual ? el.dataset.annual : el.dataset.monthly;
                    el.style.opacity = '1';
                    el.style.transform = 'translateY(0)';
                }, 150);
            });
            document.querySelectorAll('.annual-note').forEach(el => {
                el.innerHTML = isAnnual ? (el.dataset.annual || '&nbsp;') : '&nbsp;';
            });
        }
    </script>
}

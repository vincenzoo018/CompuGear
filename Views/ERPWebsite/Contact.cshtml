@{
    Layout = "~/Views/ERPWebsite/_ERPWebsiteLayout.cshtml";
    ViewData["Title"] = "Contact Us";
    ViewData["ActivePage"] = "Contact";
}

@section Styles {
    .contact-hero {
        background: linear-gradient(180deg, #f0f9f9 0%, #f8f9fc 100%);
        padding: 90px 24px 60px; text-align: center;
        position:relative; overflow:hidden;
    }
    .contact-hero::before {
        content:''; position:absolute; top:-140px; right:-140px;
        width:400px; height:400px;
        background:radial-gradient(circle,rgba(0,128,128,0.06) 0%,transparent 70%);
        border-radius:50%;
    }
    .contact-hero .badge-tag {
        display:inline-flex; align-items:center; gap:6px;
        background:rgba(0,128,128,0.08); border:1px solid rgba(0,128,128,0.15);
        padding:8px 20px; border-radius:50px;
        font-size:0.88rem; font-weight:500; color:#008080; margin-bottom:20px;
    }
    .contact-hero h1 { font-size: 2.8rem; font-weight: 800; color: #1a1a2e; margin-bottom: 16px; }
    .contact-hero p { font-size: 1.1rem; color: #666; max-width: 550px; margin: 0 auto; }

    .contact-section {
        max-width: 1000px; margin: 0 auto; padding: 70px 24px;
        display: grid; grid-template-columns: 1fr 1fr; gap: 48px;
    }

    .contact-info h2 { font-size: 1.5rem; font-weight: 700; color: #1a1a2e; margin-bottom: 24px; }
    .contact-item {
        display: flex; align-items: flex-start; gap: 16px;
        margin-bottom: 28px; padding: 16px;
        border-radius: 14px; transition: all 0.3s;
    }
    .contact-item:hover { background: #f8f9fc; transform: translateX(4px); }
    .contact-item .ci-icon {
        flex-shrink: 0; width: 52px; height: 52px; border-radius: 14px;
        background: linear-gradient(135deg, #008080, #00a5a5); color: #ffffff;
        display: flex; align-items: center; justify-content: center;
        transition: transform 0.3s;
    }
    .contact-item:hover .ci-icon { transform: scale(1.08); }
    .contact-item h4 { font-size: 0.95rem; font-weight: 600; color: #1a1a2e; margin-bottom: 4px; }
    .contact-item p { font-size: 0.9rem; color: #777; }

    .contact-form {
        background: #fff; border-radius: 20px; padding: 40px;
        border: 1px solid #eee; box-shadow: 0 4px 20px rgba(0,0,0,0.05);
    }
    .contact-form .form-group { margin-bottom: 16px; }
    .contact-form label {
        display: block; font-size: 0.85rem; font-weight: 500;
        color: #555; margin-bottom: 6px;
    }
    .contact-form input, .contact-form textarea, .contact-form select {
        width: 100%; padding: 11px 14px; border: 1.5px solid #e0e0e0;
        border-radius: 10px; font-size: 0.95rem; font-family: 'Poppins', sans-serif;
        color: #333; transition: border-color 0.2s, box-shadow 0.2s;
    }
    .contact-form input:focus, .contact-form textarea:focus, .contact-form select:focus {
        outline: none; border-color: #008080; box-shadow: 0 0 0 3px rgba(0,128,128,0.1);
    }
    .contact-form textarea { resize: vertical; min-height: 120px; }
    .contact-form .btn-send {
        width: 100%; padding: 14px 0;
        background: linear-gradient(135deg, #008080, #00a5a5); color: #fff;
        border: none; border-radius: 12px; font-size: 1rem; font-weight: 600;
        cursor: pointer; transition: all 0.3s cubic-bezier(.4,0,.2,1);
        font-family: 'Poppins', sans-serif;
        box-shadow: 0 4px 14px rgba(0,128,128,0.2);
    }
    .contact-form .btn-send:hover {
        box-shadow: 0 8px 24px rgba(0,128,128,0.3);
        transform: translateY(-1px);
    }

    /* Success message */
    .contact-success {
        display:none; text-align:center; padding:40px 20px;
    }
    .contact-success .success-icon {
        width:64px; height:64px; border-radius:50%;
        background:#10B981; color:#fff;
        display:flex; align-items:center; justify-content:center;
        margin:0 auto 16px;
        animation: fadeInScale 0.5s ease;
    }
    .contact-success h3 { font-size:1.2rem; font-weight:700; color:#1a1a2e; margin-bottom:8px; }
    .contact-success p { font-size:0.9rem; color:#777; }

    @@media (max-width: 768px) {
        .contact-hero h1 { font-size: 2rem; }
        .contact-section { grid-template-columns: 1fr; }
    }
}

<!-- Hero -->
<section class="contact-hero">
    <div class="badge-tag anim-fade-up">We're Here to Help</div>
    <h1 class="anim-fade-up anim-d1">Get In Touch</h1>
    <p class="anim-fade-up anim-d2">Have questions about CompuGear ERP? We're here to help. Reach out to our team anytime.</p>
</section>

<!-- Contact Content -->
<section class="contact-section">
    <div class="contact-info reveal">
        <h2>Contact Information</h2>

        <div class="contact-item">
            <div class="ci-icon">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
                    <polyline points="22,6 12,13 2,6"/>
                </svg>
            </div>
            <div>
                <h4>Email Us</h4>
                <p>support&#64;compugear.com</p>
                <p>sales&#64;compugear.com</p>
            </div>
        </div>

        <div class="contact-item">
            <div class="ci-icon">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
                </svg>
            </div>
            <div>
                <h4>Call Us</h4>
                <p>+63 (2) 8888-GEAR</p>
                <p>Mon-Fri, 9AM-6PM PHT</p>
            </div>
        </div>

        <div class="contact-item">
            <div class="ci-icon">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/>
                    <circle cx="12" cy="10" r="3"/>
                </svg>
            </div>
            <div>
                <h4>Visit Us</h4>
                <p>CompuGear Headquarters</p>
                <p>Manila, Philippines</p>
            </div>
        </div>
    </div>

    <!-- Contact Form -->
    <div class="contact-form reveal" id="contactFormCard">
        <div id="contactFormContent">
            <div class="form-group">
                <label>Full Name</label>
                <input type="text" placeholder="Your name" id="contactName">
            </div>
            <div class="form-group">
                <label>Email Address</label>
                <input type="email" placeholder="your&#64;email.com" id="contactEmail">
            </div>
            <div class="form-group">
                <label>Subject</label>
                <select id="contactSubject">
                    <option value="">Select a subject</option>
                    <option value="Sales Inquiry">Sales Inquiry</option>
                    <option value="Technical Support">Technical Support</option>
                    <option value="Enterprise Plan">Enterprise Plan</option>
                    <option value="Partnership">Partnership</option>
                    <option value="Other">Other</option>
                </select>
            </div>
            <div class="form-group">
                <label>Message</label>
                <textarea placeholder="How can we help you?" id="contactMessage"></textarea>
            </div>
            <button class="btn-send" onclick="sendContact()">Send Message</button>
        </div>

        <div class="contact-success" id="contactSuccess">
            <div class="success-icon">
                <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
            </div>
            <h3>Message Sent!</h3>
            <p>Thank you for reaching out. Our team will get back to you within 24 hours.</p>
        </div>
    </div>
</section>

@section Scripts {
    <script>
        function sendContact() {
            const name = document.getElementById('contactName').value.trim();
            const email = document.getElementById('contactEmail').value.trim();
            const subject = document.getElementById('contactSubject').value;
            const message = document.getElementById('contactMessage').value.trim();

            if (!name || !email || !subject || !message) {
                // Highlight empty fields
                ['contactName','contactEmail','contactSubject','contactMessage'].forEach(id => {
                    const el = document.getElementById(id);
                    if (!el.value.trim()) {
                        el.style.borderColor = '#ef4444';
                        el.style.boxShadow = '0 0 0 3px rgba(239,68,68,0.1)';
                        setTimeout(() => { el.style.borderColor = ''; el.style.boxShadow = ''; }, 2000);
                    }
                });
                return;
            }

            // Show success state with animation
            document.getElementById('contactFormContent').style.display = 'none';
            const successEl = document.getElementById('contactSuccess');
            successEl.style.display = 'block';
            successEl.style.animation = 'fadeInUp 0.5s ease';
        }
    </script>
}

@{
    ViewData["Title"] = "Inventory Reports";
    Layout = "~/Views/Shared/_InventoryLayout.cshtml";
}

<div class="page-header d-flex justify-content-between align-items-center flex-wrap gap-3">
    <div>
        <h1 class="page-title">Inventory Reports</h1>
        <p class="page-subtitle">Analyze inventory performance and trends</p>
    </div>
    <button class="btn btn-pdf-export" onclick="generateInventoryStaffPDF()">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg> Generate Report
    </button>
</div>

<div class="stat-cards">
    <div class="stat-card fade-in stagger-1">
        <div class="stat-info">
            <span class="stat-label">Total Products</span>
            <span class="stat-value" id="totalProducts">0</span>
        </div>
        <div class="stat-icon teal">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/>
            </svg>
        </div>
    </div>
    <div class="stat-card fade-in stagger-2">
        <div class="stat-info">
            <span class="stat-label">Total Stock Units</span>
            <span class="stat-value" id="totalStock">0</span>
        </div>
        <div class="stat-icon green">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M22 12h-4l-3 9L9 3l-3 9H2"/>
            </svg>
        </div>
    </div>
    <div class="stat-card fade-in stagger-3">
        <div class="stat-info">
            <span class="stat-label">Total Inventory Value</span>
            <span class="stat-value" id="totalValue">₱0</span>
        </div>
        <div class="stat-icon" style="background: var(--info); color: #ffffff;">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/>
            </svg>
        </div>
    </div>
    <div class="stat-card fade-in stagger-4">
        <div class="stat-info">
            <span class="stat-label">Avg. Value / Product</span>
            <span class="stat-value" id="avgValue">₱0</span>
        </div>
        <div class="stat-icon orange">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/>
            </svg>
        </div>
    </div>
</div>

<div class="row g-4 mb-4">
    <div class="col-lg-6">
        <div class="card fade-in h-100">
            <div class="card-header">
                <h3 class="card-title">Products by Category</h3>
            </div>
            <div class="card-body">
                <div class="chart-container" style="height: 300px;">
                    <canvas id="categoryChart"></canvas>
                </div>
            </div>
        </div>
    </div>

    <div class="col-lg-6">
        <div class="card fade-in h-100">
            <div class="card-header">
                <h3 class="card-title">Value by Category</h3>
            </div>
            <div class="card-body">
                <div class="chart-container" style="height: 300px;">
                    <canvas id="valueChart"></canvas>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        function generateInventoryStaffPDF() {
            const totalProducts = document.getElementById('totalProducts')?.textContent || '0';
            const totalStock = document.getElementById('totalStock')?.textContent || '0';
            const totalValue = document.getElementById('totalValue')?.textContent || '₱0';
            const avgValue = document.getElementById('avgValue')?.textContent || '₱0';

            // Capture chart images
            const catCanvas = document.getElementById('categoryChart');
            const valCanvas = document.getElementById('valueChart');
            const catImg = catCanvas ? catCanvas.toDataURL('image/png') : '';
            const valImg = valCanvas ? valCanvas.toDataURL('image/png') : '';

            const now = new Date();
            const html = `<!DOCTYPE html><html><head><title>Inventory Report</title>
            <style>
                body { font-family: 'Segoe UI', Arial, sans-serif; margin: 30px; color: #333; }
                .header { text-align: center; border-bottom: 2px solid #008080; padding-bottom: 12px; margin-bottom: 20px; }
                .header h1 { color: #008080; margin: 0 0 4px 0; font-size: 22px; }
                .header p { margin: 0; font-size: 12px; color: #666; }
                .stats { display: flex; gap: 16px; margin-bottom: 24px; }
                .stat-box { flex: 1; border: 1px solid #ddd; border-radius: 8px; padding: 14px; text-align: center; }
                .stat-box .label { font-size: 11px; color: #666; text-transform: uppercase; }
                .stat-box .value { font-size: 20px; font-weight: 700; color: #008080; margin-top: 4px; }
                .charts { display: flex; gap: 20px; margin-top: 20px; }
                .chart-box { flex: 1; text-align: center; }
                .chart-box h3 { font-size: 14px; color: #555; margin-bottom: 10px; }
                .chart-box img { max-width: 100%; max-height: 280px; }
                .footer { text-align: center; margin-top: 30px; padding-top: 12px; border-top: 1px solid #ddd; font-size: 11px; color: #999; }
                @@media print { body { margin: 15px; } .no-print { display: none; } }
            </style></head><body>
            <div class="header">
                <h1>CompuGear - Inventory Report</h1>
                <p>Generated: ${now.toLocaleString()}</p>
            </div>
            <div class="stats">
                <div class="stat-box"><div class="label">Total Products</div><div class="value">${totalProducts}</div></div>
                <div class="stat-box"><div class="label">Total Stock Units</div><div class="value">${totalStock}</div></div>
                <div class="stat-box"><div class="label">Total Inventory Value</div><div class="value">${totalValue}</div></div>
                <div class="stat-box"><div class="label">Avg. Value / Product</div><div class="value">${avgValue}</div></div>
            </div>
            <div class="charts">
                ${catImg ? `<div class="chart-box"><h3>Products by Category</h3><img src="${catImg}"></div>` : ''}
                ${valImg ? `<div class="chart-box"><h3>Value by Category</h3><img src="${valImg}"></div>` : ''}
            </div>
            <div class="footer">CompuGear Inventory Management System</div>
            <script>window.onload=function(){window.print();}<\/script>
            </body></html>`;

            const w = window.open('', '_blank');
            w.document.write(html);
            w.document.close();
        }
    </script>
}

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        function handleSearch(event) {
            if (event.key === 'Enter') { doSearch(); }
        }
        function doSearch() {
            const query = document.getElementById('globalSearch').value.trim();
            if (query) {
                window.location.href = '/CustomerPortal/Products?search=' + encodeURIComponent(query);
            }
        }

        function updateCartBadge() {
            const cart = JSON.parse(localStorage.getItem('cart') || '[]');
            const totalItems = cart.reduce((sum, item) => sum + (item.quantity || 1), 0);
            const badge = document.getElementById('cartBadge');
            if (badge) {
                if (totalItems > 0) { badge.textContent = totalItems; badge.style.display = 'flex'; }
                else { badge.style.display = 'none'; }
            }
        }

        function updateWishlistBadge() {
            const wishlist = JSON.parse(localStorage.getItem('wishlist') || '[]');
            const badge = document.getElementById('wishlistBadge');
            if (badge) {
                if (wishlist.length > 0) { badge.textContent = wishlist.length; badge.style.display = 'flex'; }
                else { badge.style.display = 'none'; }
            }
        }

        window.addToCart = function(product) {
            let cart = JSON.parse(localStorage.getItem('cart') || '[]');
            const existing = cart.find(item => item.productId === product.productId);
            if (existing) { existing.quantity = (existing.quantity || 1) + 1; }
            else { cart.push({ ...product, quantity: 1 }); }
            localStorage.setItem('cart', JSON.stringify(cart));
            window.dispatchEvent(new Event('cartUpdated'));
        };

        window.toggleWishlist = function(product) {
            let wishlist = JSON.parse(localStorage.getItem('wishlist') || '[]');
            const idx = wishlist.findIndex(item => item.productId === product.productId);
            if (idx >= 0) { wishlist.splice(idx, 1); }
            else { wishlist.push(product); }
            localStorage.setItem('wishlist', JSON.stringify(wishlist));
            window.dispatchEvent(new Event('wishlistUpdated'));
        };

        window.addEventListener('cartUpdated', updateCartBadge);
        window.addEventListener('wishlistUpdated', updateWishlistBadge);
        window.addEventListener('storage', function(e) {
            if (e.key === 'cart') updateCartBadge();
            if (e.key === 'wishlist') updateWishlistBadge();
        });

        
        // ========== NOTIFICATION SYSTEM ==========
        let notifDropdownOpen = false;
        let notifPollingInterval = null;

        function toggleNotifDropdown(e) {
            e.stopPropagation();
            const dropdown = document.getElementById('notifDropdown');
            notifDropdownOpen = !notifDropdownOpen;
            if (notifDropdownOpen) {
                dropdown.classList.add('open');
                loadNotifications();
            } else {
                dropdown.classList.remove('open');
            }
        }

        // Close dropdown when clicking outside
        document.addEventListener('click', function(e) {
            const bell = document.getElementById('notifBell');
            if (bell && !bell.contains(e.target)) {
                const dropdown = document.getElementById('notifDropdown');
                if (dropdown) { dropdown.classList.remove('open'); notifDropdownOpen = false; }
            }
        });

        function getNotifIcon(type) {
            switch(type) {
                case 'order': return '';
                case 'promo': return '';
                case 'support': return '';
                default: return '';
            }
        }

        function getNotifIconClass(type) {
            if (type === 'order') return 'order';
            if (type === 'promo') return 'promo';
            if (type === 'support') return 'support';
            return 'system';
        }

        function timeAgo(dateStr) {
            const now = new Date();
            const d = new Date(dateStr);
            const diff = Math.floor((now - d) / 1000);
            if (diff < 60) return 'Just now';
            if (diff < 3600) return Math.floor(diff / 60) + 'm ago';
            if (diff < 86400) return Math.floor(diff / 3600) + 'h ago';
            if (diff < 604800) return Math.floor(diff / 86400) + 'd ago';
            return d.toLocaleDateString();
        }

        async function loadNotifications() {
            try {
                const resp = await fetch('/CustomerPortal/GetNotifications?pageSize=15');
                const result = await resp.json();
                if (!result.success) return;

                const list = document.getElementById('notifList');
                if (!result.data || result.data.length === 0) {
                    list.innerHTML = '<div class="notif-empty"><div class="notif-empty-icon"></div><p>No notifications yet</p></div>';
                    return;
                }

                list.innerHTML = result.data.map(n => `
                    <a class="notif-item ${n.isRead ? '' : 'unread'}" href="${n.link || '#'}" onclick="markNotifRead(event, ${n.notificationId}, '${n.link || ''}')">
                        <div class="notif-icon-wrap ${getNotifIconClass(n.type)}">${getNotifIcon(n.type)}</div>
                        <div class="notif-content">
                            <div class="notif-title">${n.title}</div>
                            <div class="notif-msg">${n.message || ''}</div>
                            <div class="notif-time">${timeAgo(n.createdAt)}</div>
                        </div>
                        ${n.isRead ? '' : '<div class="notif-unread-dot"></div>'}
                    </a>
                `).join('');
            } catch (err) {
                console.error('Notification load error:', err);
            }
        }

        async function updateNotifBadge() {
            try {
                const resp = await fetch('/CustomerPortal/GetUnreadNotificationCount');
                const result = await resp.json();
                const badge = document.getElementById('notifBadge');
                if (badge) {
                    if (result.count > 0) {
                        badge.textContent = result.count > 99 ? '99+' : result.count;
                        badge.classList.add('visible');
                    } else {
                        badge.classList.remove('visible');
                    }
                }
            } catch (err) { /* silent */ }
        }

        async function markNotifRead(e, notifId, link) {
            e.preventDefault();
            e.stopPropagation();
            try {
                await fetch('/CustomerPortal/MarkNotificationRead', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ notificationId: notifId })
                });
                updateNotifBadge();
            } catch (err) { /* silent */ }
            if (link && link !== '#') {
                window.location.href = link;
            } else {
                loadNotifications();
            }
        }

        async function markAllNotifRead(e) {
            e.preventDefault();
            e.stopPropagation();
            try {
                await fetch('/CustomerPortal/MarkAllNotificationsRead', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' }
                });
                updateNotifBadge();
                loadNotifications();
            } catch (err) { /* silent */ }
        }

        // Real-time: poll every 30 seconds
        function startNotifPolling() {
            updateNotifBadge();
            notifPollingInterval = setInterval(updateNotifBadge, 30000);
        }

        document.addEventListener('DOMContentLoaded', function() {
            updateCartBadge();
            updateWishlistBadge();
            startNotifPolling();
            window.addEventListener('scroll', function() {
                const navbar = document.getElementById('navbar');
                const scrollTop = document.getElementById('scrollTop');
                if (window.scrollY > 50) { navbar.classList.add('scrolled'); } else { navbar.classList.remove('scrolled'); }
                if (window.scrollY > 300) { scrollTop.classList.add('visible'); } else { scrollTop.classList.remove('visible'); }
            });
        });
    </script>
        <script>
        // ===== HELP CENTER =====
        let hcCategories = [], hcAllArticles = [], hcCurrentArticleId = null, hcPreviousView = 'categories';
        const catIcons = ['','','','','','','','','','','',''];
        function toggleHelpCenter() {
            const panel = document.getElementById('helpCenterPanel');
            const overlay = document.getElementById('helpCenterOverlay');
            const fab = document.getElementById('helpCenterFab');
            const isOpen = panel.classList.contains('open');
            if (isOpen) {
                panel.classList.remove('open'); overlay.classList.remove('open'); fab.classList.remove('active');
            } else {
                panel.classList.add('open'); overlay.classList.add('open'); fab.classList.add('active');
                if (hcCategories.length === 0) hcLoadData();
            }
        }
        async function hcLoadData() {
            ['hcCategoriesView','hcArticlesView','hcArticleView','hcSearchView'].forEach(id => {
                const el = document.getElementById(id); if(el) el.style.display='none';
            });
            document.getElementById('hcEmpty').style.display='none';
            const loadingEl = document.createElement('div');
            loadingEl.className='hc-loading'; loadingEl.id='hcLoadingSpinner';
            loadingEl.innerHTML='<div class="hc-spinner"></div>';
            document.getElementById('hcBody').appendChild(loadingEl);
            try {
                const [catRes, artRes] = await Promise.all([
                    fetch('/CustomerPortal/GetHelpCategories'), fetch('/CustomerPortal/GetHelpArticles')
                ]);
                if (!catRes.ok || !artRes.ok) throw new Error('API error');
                hcCategories = await catRes.json(); hcAllArticles = await artRes.json();
                const spinner = document.getElementById('hcLoadingSpinner'); if(spinner) spinner.remove();
                hcRenderCategories(); hcRenderPopular();
                document.getElementById('hcCategoriesView').style.display='';
            } catch(e) {
                const spinner = document.getElementById('hcLoadingSpinner'); if(spinner) spinner.remove();
                document.getElementById('hcEmpty').style.display='';
                document.getElementById('hcEmpty').querySelector('p').textContent='Unable to load help articles';
            }
        }
        function hcRenderCategories() {
            const el = document.getElementById('hcCategoriesList'); if(!el) return;
            el.innerHTML = hcCategories.map((c,i) => 
                '<div class="hc-cat-card" onclick="hcShowCategory('+c.categoryId+',\''+hcEsc(c.categoryName)+'\')">'+
                '<span class="hc-cat-icon">'+(catIcons[i%catIcons.length])+'</span>'+
                '<div class="hc-cat-name">'+hcEsc(c.categoryName)+'</div>'+
                '<div class="hc-cat-count">'+c.articleCount+' article'+(c.articleCount!==1?'s':'')+'</div></div>'
            ).join('');
        }
        function hcRenderPopular() {
            const el = document.getElementById('hcPopularArticles'); if(!el) return;
            const popular = hcAllArticles.slice(0,5);
            el.innerHTML = popular.map(a => hcArticleCard(a)).join('');
            if(!popular.length) el.innerHTML = '<p style="color:#9ca3af;font-size:.85rem;">No articles yet</p>';
        }
        function hcArticleCard(a) {
            const cat = hcCategories.find(c=>c.categoryId===a.categoryId);
            return '<div class="hc-article-item" onclick="hcViewArticle('+a.articleId+')">'+
                '<div class="hc-article-item-icon"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg></div>'+
                '<div class="hc-article-item-info"><div class="hc-article-item-title">'+hcEsc(a.title)+'</div>'+
                '<div class="hc-article-item-meta"><span>'+(cat?hcEsc(cat.categoryName):'')+'</span><span>'+a.viewCount+' views</span></div></div></div>';
        }
        function hcShowCategory(catId, catName) {
            hcPreviousView='categories';
            const articles = hcAllArticles.filter(a=>a.categoryId===catId);
            document.getElementById('hcCategoryTitle').textContent = catName;
            document.getElementById('hcArticlesList').innerHTML = articles.length ? articles.map(a=>hcArticleCard(a)).join('') : '<div class="hc-empty"><p>No articles in this category</p></div>';
            hcSwitchView('hcArticlesView');
        }
        function hcShowCategories() { hcSwitchView('hcCategoriesView'); }
        async function hcViewArticle(id) {
            if(document.getElementById('hcArticlesView').style.display!=='none') hcPreviousView='articles';
            else if(document.getElementById('hcSearchView').style.display!=='none') hcPreviousView='search';
            else hcPreviousView='categories';
            hcCurrentArticleId = id;
            hcSwitchView('hcArticleView');
            document.getElementById('hcArticleContent').innerHTML='<div class="hc-loading"><div class="hc-spinner"></div></div>';
            try {
                const res = await fetch('/CustomerPortal/GetHelpArticle?id='+id);
                const a = await res.json();
                const cat = hcCategories.find(c=>c.categoryId===a.categoryId);
                document.getElementById('hcArticleCat').textContent = cat ? cat.categoryName : '';
                document.getElementById('hcArticleTitle').textContent = a.title;
                document.getElementById('hcArticleMeta').innerHTML = '<span>'+a.viewCount+' views</span><span>'+new Date(a.publishedAt||a.createdAt).toLocaleDateString()+'</span>';
                document.getElementById('hcArticleContent').innerHTML = a.content || a.summary || 'No content available';
                document.getElementById('hcArticleFeedback').style.display='';
                document.querySelectorAll('.hc-fb-btn').forEach(b=>{b.classList.remove('selected');b.style.pointerEvents='';});
            } catch(e) { document.getElementById('hcArticleContent').innerHTML='<p style="color:#ef4444;">Failed to load article</p>'; }
        }
        function hcGoBackFromArticle() { hcSwitchView(hcPreviousView==='articles'?'hcArticlesView':hcPreviousView==='search'?'hcSearchView':'hcCategoriesView'); }
        let hcSearchTimeout;
        function hcSearchArticles() {
            clearTimeout(hcSearchTimeout);
            const q = document.getElementById('hcSearchInput').value.trim();
            if(!q) { hcClearSearch(); return; }
            hcSearchTimeout = setTimeout(async () => {
                hcSwitchView('hcSearchView');
                document.getElementById('hcSearchResults').innerHTML='<div class="hc-loading"><div class="hc-spinner"></div></div>';
                try {
                    const res = await fetch('/CustomerPortal/GetHelpArticles?search='+encodeURIComponent(q));
                    const articles = await res.json();
                    document.getElementById('hcSearchLabel').textContent='Search Results ('+articles.length+')';
                    document.getElementById('hcSearchResults').innerHTML = articles.length ? articles.map(a=>hcArticleCard(a)).join('') : '';
                    document.getElementById('hcEmpty').style.display = articles.length ? 'none' : '';
                } catch(e) { document.getElementById('hcSearchResults').innerHTML='<p style="color:#ef4444;">Search failed</p>'; }
            }, 300);
        }
        function hcClearSearch() { document.getElementById('hcSearchInput').value=''; hcSwitchView('hcCategoriesView'); document.getElementById('hcEmpty').style.display='none'; }
        async function hcRateArticle(helpful) {
            try {
                await fetch('/CustomerPortal/RateHelpArticle', { method:'POST', headers:{'Content-Type':'application/json'}, body:JSON.stringify({articleId:hcCurrentArticleId,helpful:helpful}) });
                document.querySelectorAll('.hc-fb-btn').forEach(b=>b.style.pointerEvents='none');
                document.querySelector(helpful?'.hc-fb-yes':'.hc-fb-no').classList.add('selected');
            } catch(e) {}
        }
        function hcSwitchView(viewId) {
            ['hcCategoriesView','hcArticlesView','hcArticleView','hcSearchView'].forEach(id => {
                const el = document.getElementById(id); if(el) el.style.display = id===viewId ? '' : 'none';
            });
            document.getElementById('hcEmpty').style.display='none';
        }
        function hcEsc(s) { const d=document.createElement('div'); d.textContent=s; return d.innerHTML; }
    </script>
    @await RenderSectionAsync("Scripts", required: false)
